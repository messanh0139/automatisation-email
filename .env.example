# Copie ce fichier en ".env" (jamais commité) et remplis les vraies valeurs.

# Chaîne de connexion du projet Neon (console Neon > Connection Details)
DATABASE_URL=

# Clé API OpenAI (platform.openai.com > API Keys)
OPENAI_API_KEY=

# SMTP direct (ton compte email personnel) — envoi de la réponse (F4)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# IMAP — relève de la boîte de réception (F1). Même compte que le SMTP ci-dessus.
IMAP_HOST=
IMAP_PORT=

# HubSpot — synchronisation des tickets CRM (F7)
HUBSPOT_ACCESS_TOKEN=
